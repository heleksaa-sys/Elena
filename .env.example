# Copy to .env on the VPS. Never commit the real .env.
# All values shown are defaults — override only what you need.

# === OpenClaw core ===
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_GATEWAY_PORT=18789
# loopback = безопаснее, наружу проксирует Caddy. Не меняй без причины.
OPENCLAW_GATEWAY_BIND=loopback
OPENCLAW_CONFIG_DIR=/root/.openclaw
OPENCLAW_WORKSPACE_DIR=/root/.openclaw/workspace
OPENCLAW_TZ=Europe/Moscow

# === Auth ===
# Сгенерируется bootstrap-скриптом если пусто. Хранить в GitHub Secrets.
OPENCLAW_GATEWAY_TOKEN=
GOG_KEYRING_PASSWORD=

# === Caddy / TLS ===
# Домен с A-записью на IP VPS. Если "" — Caddy слушает только :80 без TLS.
DOMAIN=
# Email для уведомлений Let's Encrypt о просрочке
ACME_EMAIL=

# === LLM провайдер (один из) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Для локальных моделей через Ollama — оставить пусто, поднимаем отдельно.
